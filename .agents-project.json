{
  "$schema": "https://raw.githubusercontent.com/ericthayer/agents-config/main/schemas/agents-project.schema.json",
  "version": "1.0.0",
  "project": {
    "name": "yofolio",
    "framework": "react",
    "styling": "mui",
    "database": "supabase"
  },
  "agents": [
    "gemini"
  ],
  "features": {
    "gemini": true,
    "storybook": false,
    "threejs": true
  },
  "rules": {
    "include": [
      "accessibility",
      "component-architecture",
      "spec-driven-development",
      "web-performance",
      "mui",
      "supabase",
      "gemini",
      "three-js-react",
      "web-performance"
    ],
    "exclude": []
  },
  "overrides": {}
}